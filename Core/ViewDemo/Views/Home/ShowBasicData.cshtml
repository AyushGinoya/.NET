@{
}

@model ViewDemo.Models.User

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <h3>Registered Information</h3>
            <table class="table table-bordered">
                <tr>
                    <th>Name</th>
                    <td>@Model.Name</td>
                </tr>
                <tr>
                    <th>Area</th>
                    <td>@Model.Area</td>
                </tr>
                <tr>
                    <th>Gender</th>
                    <td>@Model.Gender</td>
                </tr>
                <tr>
                    <th>Course</th>
                    <td>@Model.Course</td>
                </tr>
            </table>
        </div>
    </div>
</div>