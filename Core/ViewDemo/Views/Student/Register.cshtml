@model ViewDemo.Models.Student
@{
    ViewData["Title"] = "Student Registration";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4>🎓 Student Registration</h4>
                </div>
                <div class="card-body">

                    @Html.ValidationSummary(false, "", new { @class = "text-danger" })

                    @using (Html.BeginForm("Register", "Student", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            @Html.LabelFor(m => m.Name, new { @class = "form-label fw-bold" })
                            @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = "Enter your name" })
                            @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(m => m.Age, new { @class = "form-label fw-bold" })
                            @Html.TextBoxFor(m => m.Age, new { @class = "form-control", placeholder = "Enter your age" })
                            @Html.ValidationMessageFor(m => m.Age, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(m => m.Email, new { @class = "form-label fw-bold" })
                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Enter your email" })
                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(m => m.Gender, new { @class = "form-label fw-bold" })
                            <div>
                                @Html.RadioButtonFor(m => m.Gender, "Female", new { id = "female" })
                                <label for="female">Female</label> &nbsp;&nbsp;
                                @Html.RadioButtonFor(m => m.Gender, "Male", new { id = "male" })
                                <label for="male">Male</label>
                            </div>
                            @Html.ValidationMessageFor(m => m.Gender, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(m => m.Course, new { @class = "form-label fw-bold" })
                            @Html.DropDownListFor(m => m.Course, ViewBag.CourseList as SelectList, "--Select Course--", new { @class = "form-select" })
                            @Html.ValidationMessageFor(m => m.Course, "", new { @class = "text-danger small" })
                        </div>

                        <div class="d-flex gap-2">
                            <input type="submit" value="Register" class="btn btn-success" />
                            <a href="/Student/Register" class="btn btn-secondary">Clear</a>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Html.Partial("_ValidationScriptsPartial")
}